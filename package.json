{
  "name": "@lanying/clawchat",
  "version": "1.0.29",
  "private": false,
  "description": "OpenClaw ClawChat IM channel plugin",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "latest",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "index.ts",
    "src",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": ["./index.ts"],
    "runtimeExtensions": ["./dist/index.js"]
  }
}
